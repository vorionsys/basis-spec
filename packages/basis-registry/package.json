{
  "name": "@vorionsys/basis-registry",
  "version": "0.1.0",
  "description": "BASIS reference library of verifiable primitives — self-certifying CAR identifiers and an RFC-6962 append-only Merkle transparency log, with fully OFFLINE, fail-closed verification (no server call, no DID resolution). A LIBRARY of primitives, not a running registry.",
  "keywords": [
    "ai",
    "agent",
    "governance",
    "trust",
    "transparency-log",
    "rfc6962",
    "merkle",
    "did-key",
    "self-certifying",
    "fail-closed",
    "basis"
  ],
  "homepage": "https://github.com/vorionsys/basis-spec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/basis-spec.git",
    "directory": "packages/basis-registry"
  },
  "bugs": "https://github.com/vorionsys/basis-spec/issues",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./identity": {
      "types": "./dist/identity.d.ts",
      "import": "./dist/identity.js"
    },
    "./log": {
      "types": "./dist/log.d.ts",
      "import": "./dist/log.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vorionsys/basis-spec": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": "true"
  }
}
