{
  "name": "@basis-spec/basis-conformance",
  "version": "0.1.0",
  "description": "BASIS conformance test suite — runs against @basis-spec/basis to verify the spec is internally coherent. Vendor-endpoint mode coming in v0.2.",
  "keywords": [
    "ai",
    "agent",
    "governance",
    "trust",
    "conformance",
    "test-suite",
    "basis"
  ],
  "homepage": "https://github.com/vorionsys/basis-spec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/basis-spec.git",
    "directory": "packages/basis-conformance"
  },
  "bugs": "https://github.com/vorionsys/basis-spec/issues",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "basis-conformance": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "conformance": "vitest run --reporter=default --reporter=json --outputFile=conformance-results.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@basis-spec/basis": "^1.1.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
