{
  "name": "@vorionsys/basis-scorer",
  "version": "0.1.0",
  "description": "BASIS reference scorer — deterministic evidence→score→tier with fail-closed effectiveTier = min(claimed, recomputed, observation ceiling, policy ceiling), the frozen CAR-5⇄T0–T7 projection, and golden vectors. Built on @vorionsys/basis-spec.",
  "keywords": [
    "ai",
    "agent",
    "trust",
    "governance",
    "scorer",
    "basis",
    "tier",
    "effective-tier",
    "fail-closed"
  ],
  "homepage": "https://vorion.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/basis-spec.git",
    "directory": "packages/basis-scorer"
  },
  "bugs": {
    "url": "https://github.com/vorionsys/basis-spec/issues"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./golden-vectors": {
      "types": "./dist/golden-vectors.d.ts",
      "import": "./dist/golden-vectors.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vorionsys/basis-spec": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Vorion LLC",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
